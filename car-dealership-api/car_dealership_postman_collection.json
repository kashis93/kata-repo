						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"customerToken\", jsonData.access_token);",
									"    console.log(\"Saved customerToken: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
